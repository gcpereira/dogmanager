generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Dog {
  id            Int      @id @default(autoincrement())
  name          String
  age           Int?
  gender        String
  tutorName     String
  tutorPhone    String
  allergies     String?
  behaviorNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  visits       Visit[]
  photos       Photo[]
  appointments Appointment[]
}

model Visit {
  id         Int      @id @default(autoincrement())
  dogId      Int
  dog        Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  date       DateTime
  valueCents Int
  notes      String?
  createdAt  DateTime @default(now())

  @@index([dogId, date])
}

model Photo {
  id        Int      @id @default(autoincrement())
  dogId     Int
  dog       Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  filename  String
  createdAt DateTime @default(now())

  @@index([dogId, createdAt])
}

model Appointment {
  id          Int      @id @default(autoincrement())
  dogId       Int
  dog         Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  durationMin Int      @default(60)
  service     String?
  createdAt   DateTime @default(now())

  @@index([startsAt])
}
